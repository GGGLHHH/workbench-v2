# workbench-v2 本地三服务端口 —— 单一真相源。vite / bff / server 三处配置全从这里派生。
# 用法:cp .env.example .env,按需改端口(.env 已 gitignore)。改端口只改这一份,
# BFF↔server 的转发接线会自动跟随,不会再出现「server 换端口但 BFF 还指旧口」的错位。

# 前端 vite dev server
WEB_PORT=5173
# BFF:前端唯一入口(/api 与 /bff 全打这里),内部再分流到 server 与 xchangeai
BFF_PORT=4100
# 渲染/素材服务 server:编辑器 transport 的实现方,素材/产物落盘 .data
RENDER_PORT=3011

# 下游 xchangeai-server(Go,业务数据面):本仓不启动它,填它的地址即可
XCHANGE_UPSTREAM=http://localhost:8080

# ——— AI 图生视频(clip 生成)provider ———
# server 的 clip 服务按 VIDEO_PROVIDER 选默认 provider(缺省 ltx-2-3-fast);每 provider 需其 API key。
# base64/data-uri 类(Gemini/Veo/fal-Kling)本地开箱可用;public-url 类(Seedance/Runway/Luma/MiniMax/LTX)
# 需输入图为公网 URL —— 真实流程里由 BFF 从 xchangeai content 解析出公网 download_url,无需 R2。
# 值从有权限的来源填(勿提交真值;.env 已 gitignore)。
VIDEO_PROVIDER=ltx-2-3-fast

# Google(Gemini Omni + Veo 3.1/fast/lite):base64,本地可用
GEMINI_API_KEY=
GEMINI_OMNI_MODEL=gemini-omni-flash-preview
VEO_MODEL=veo-3.1-generate-preview
VEO_FAST_MODEL=veo-3.1-fast-generate-preview
VEO_LITE_MODEL=veo-3.1-lite-generate-preview

# fal(Kling 2.1):data-uri,本地可用
FAL_KEY=
FAL_KLING_MODEL=fal-ai/kling-video/v2.1/standard/image-to-video

# 以下为 public-url provider(需公网输入图 URL)
# Runway Gen-4 / 4.5
RUNWAY_API_KEY=
RUNWAY_BASE_URL=https://api.dev.runwayml.com
RUNWAY_API_VERSION=2024-11-06
# Luma Ray 2 / flash
LUMA_API_KEY=
LUMA_BASE_URL=https://api.lumalabs.ai
# MiniMax / Hailuo
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io
# LTX 2.3 Fast(默认 provider)
LTX_API_KEY=
LTX_BASE_URL=https://api.ltx.video
LTX_MODEL=ltx-2-3-fast
LTX_RESOLUTION=1920x1080
LTX_FPS=24
# Seedance 2.0
SEEDANCE_API_KEY=
SEEDANCE_BASE_URL=https://api.seedance2.ai
SEEDANCE_MODEL=seedance-2-0
# 本地无公网图片时,可临时放开 http 输入图(仅本机调试用)
# ALLOW_HTTP_IMAGE_URLS=1
